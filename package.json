{
  "name": "@crow-b3/local-dev",
  "version": "0.0.1",
  "description": "Clone and sync all CROW-B3 repositories",
  "type": "module",
  "scripts": {
    "start": "bun run src/start.ts",
    "clone": "bun run src/clone.ts",
    "sync": "bun run src/sync.ts",
    "clean": "bun run src/clean.ts",
    "checkout": "bun run src/checkout.ts",
    "clone:all": "bun run src/clone.ts --all",
    "sync:force": "bun run src/sync.ts --force",
    "cleanup:dev": "bun run src/cleanup.ts --env dev",
    "cleanup:prod": "bun run src/cleanup.ts --env prod",
    "clean:dev": "bun run src/cleanup-tables.ts --env dev",
    "clean:prod": "bun run src/cleanup-tables.ts --env prod"
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/yargs": "17.0.35",
    "concurrently": "^9.2.1"
  },
  "keywords": [
    "crow-b3",
    "local-dev"
  ],
  "author": "CROW-B3",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.992.0",
    "@inquirer/prompts": "^8.1.0",
    "hono": "^4.11.9",
    "yargs": "18.0.0"
  }
}
